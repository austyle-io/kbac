# Neo4j connection settings for the kbac graph.
#
# Setup:
#   1. cp .env.example .env
#   2. Fill in NEO4J_PASSWORD (any strong password — used by the Neo4j
#      container on first launch). Subsequent yarn db:up / yarn db:reset
#      runs must use the SAME password or the container auth will fail.
#   3. .env is gitignored — never commit secrets.
#
# Precedence: real env vars (exported in shell or set inline like
#   `NEO4J_PASSWORD=foo kbac search ...`) win over .env values.

NEO4J_URI=bolt://localhost:7688
NEO4J_USERNAME=neo4j
NEO4J_DATABASE=neo4j
NEO4J_PASSWORD=
