#!/usr/bin/env bash
# bin/kbac — wrapper that loads .env (via Node's native --env-file-if-exists)
# and runs bin/kbac.ts. Designed to be symlinked into ~/.local/bin so the
# binary resolves on $PATH from any working directory.
#
# Env precedence: real env vars (exported or set inline) win over .env.
# Node's --env-file does NOT overwrite already-set variables, so callers
# can do `NEO4J_PASSWORD=... kbac search ...` to override on the fly.
# When .env is absent (e.g. CI), the flag is a no-op and the process
# uses whatever env vars the caller supplied.

set -euo pipefail

# Resolve symlinks so we can find the repo root even when invoked via
# ~/.local/bin/kbac. `readlink -f` works on macOS >= 12.3 (Monterey) and
# modern Linux, but the loop below is the BSD-compatible equivalent for
# older systems where -f may be missing.
target="${BASH_SOURCE[0]}"
while [ -L "$target" ]; do
  link="$(readlink "$target")"
  case "$link" in
    /*) target="$link" ;;
    *)  target="$(cd "$(dirname "$target")" && pwd)/$link" ;;
  esac
done
repo_root="$(cd "$(dirname "$target")/.." && pwd)"

# Node-version preflight: --env-file-if-exists was added in Node 22.9.0
# (https://nodejs.org/api/cli.html). Older Node versions silently fail
# with "is not allowed in NODE_OPTIONS" or accept the flag with no effect.
node_version="$(node --version 2>/dev/null || echo 'v0.0.0')"
node_major="${node_version#v}"; node_major="${node_major%%.*}"
node_minor="${node_version#v*.}"; node_minor="${node_minor%%.*}"
if [ "$node_major" -lt 22 ] || { [ "$node_major" -eq 22 ] && [ "$node_minor" -lt 9 ]; }; then
  echo "kbac: Node $node_version is too old; --env-file-if-exists requires Node >= 22.9.0" >&2
  echo "kbac: upgrade via 'brew upgrade node' or your version manager" >&2
  exit 127
fi

cd "$repo_root"
exec node --env-file-if-exists=.env --import tsx bin/kbac.ts "$@"
